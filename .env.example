# Copy to `.env` (gitignored) and fill in for local dev (`npm start` / `npm run test:zotero`).
# Not needed for `npm run build` or the Vitest unit tests.

# Path to the Zotero binary.
#   macOS:   /Applications/Zotero.app/Contents/MacOS/zotero
#   Windows: C:\\Program Files\\Zotero\\zotero.exe   (escape backslashes)
#   Linux:   /usr/lib/zotero/zotero
ZOTERO_PLUGIN_ZOTERO_BIN_PATH = /Applications/Zotero.app/Contents/MacOS/zotero

# A DEDICATED development profile (do NOT use your everyday profile).
# Create one with: /path/to/zotero -p
ZOTERO_PLUGIN_PROFILE_PATH =

# Optional: data dir for the dev profile. Empty = Zotero default.
ZOTERO_PLUGIN_DATA_DIR =

# Optional: GitHub token for `npm run release` when publishing locally (not in CI).
# GITHUB_TOKEN =
